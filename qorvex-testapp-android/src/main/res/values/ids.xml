<?xml version="1.0" encoding="utf-8"?>
<!--
  Declared view ids so that AccessibilityNodeInfo.viewIdResourceName reports a
  stable bare entry name (e.g. "controls_tap_button"), which the Kotlin agent's
  NodeMapper.bareResourceId returns as UIElement.identifier (ADR-1). These are
  the 1:1 underscore transliteration of the iOS hyphenated accessibility ids.

  Kept in sync with com.qorvex.testapp.Ids — IdsCompletenessTest asserts every
  Ids.* constant has a matching @id here.
-->
